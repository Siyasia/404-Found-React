# Example values for environment variables. Copy this file to .env and change the values as needed.

# Path to the SQLite database file. The API server will create this file if it doesn't exist.
DATABASE_FILE=database.db
# Base path for the API. The frontend will use this to construct the full API URL.
API_BASE=/api
# Port the API server should bind to
API_PORT=8081
# The address the API server should bind to. In almost all cases, this should be 0.0.0.0
BIND_ADDRESS=0.0.0.0
# Base URL for the API, without port or path. The frontend will use this to construct the full API URL.
API_URL=http://localhost

# Exact URL the frontend will be served on, excluding http/s
VITE_URL=localhost:5173
# Port the frontend server should bind to
VITE_PORT=5173

# don't touch this unless the API url binds on a different public port than API_PORT in case of a reverse proxy, or any other similar
# setup where the autogenerated API url would be different from the actual URL the frontend should use to access the API.
# In that case, set this variable to the exact URL the frontend should use to access the API, including port and path.
# eg. api.example.com:8081/api, or localhost:8081/api
VITE_API_URL=${API_URL}:${API_PORT}${API_BASE}
